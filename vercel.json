{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/dashboard", "destination": "/api/dashboard" }
  ],
  "crons": [
    { "path": "/api/wabistay/cron/auto-checkout", "schedule": "*/5 * * * *" },
    { "path": "/api/wabistay/cron/owner-summary", "schedule": "0 6 * * 1" }
  ]
}
