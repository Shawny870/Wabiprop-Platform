{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/dashboard", "destination": "/api/dashboard" }
  ],
  "crons": [
    { "path": "/api/wabiprop/cron/owner-weekly", "schedule": "0 5 * * 1" },
    { "path": "/api/wabiprop/cron/agent-morning-summary", "schedule": "0 5 * * *" }
  ]
}
