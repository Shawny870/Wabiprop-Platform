{
  "name": "details: name + dates creates Enquiry booking, writes Booking Ref (F13), notifies owner (F7), asks ETA",
  "seed": {
    "WS_Properties": [
      { "id": "recP1", "fields": { "Property Name": "Test Lodge", "Phone Number ID": "111000111000", "City": "Testville", "Notify Phone": "27831112222" } }
    ],
    "WS_Rates": [
      { "id": "recRATE1", "fields": { "Rate Name": "Standard Overnight", "Rate Type": "Per Night", "Amount": 350, "Active": true, "Property": ["recP1"] } }
    ],
    "WS_Guests": [
      { "id": "recG1", "fields": { "Guest Name": "Unknown", "Phone Number": "27821234567", "Session State": "AWAITING_DETAILS" } }
    ],
    "WS_Cleaners": [],
    "WS_Bookings": []
  },
  "message": { "from": "27821234567", "text": "John Smith\n25 June\n27 June" },
  "expect": {
    "status": 200,
    "writes": [
      { "op": "update", "table": "WS_Guests", "id": "recG1", "fields": { "Guest Name": "John Smith", "Session State": "AWAITING_ETA" } },
      {
        "op": "create", "table": "WS_Bookings",
        "fields": {
          "Guest": ["recG1"],
          "Booking Type": "Overnight",
          "Source": "WhatsApp",
          "Status": "Enquiry",
          "Logged By": "WhatsApp Bot",
          "Notes": "Check-in: 25 June | Check-out: 27 June",
          "Payment Status": "Unpaid",
          "Rate Applied": ["recRATE1"],
          "Amount Due": 350
        }
      },
      { "op": "update", "table": "WS_Bookings", "fields": { "Booking Ref": "re:^WS-[A-Z0-9]{6}$" } }
    ],
    "sends": [
      { "to": "27830000001", "includes": ["New booking enquiry from John Smith", "Phone: 27821234567", "Check-in: 25 June", "Check-out: 27 June"] },
      { "to": "27821234567", "includes": ["Thanks John Smith", "*Ref:* WS-", "*Check-in:* 25 June", "*Check-out:* 27 June", "R350 per night", "What time do you expect to arrive"] }
    ]
  }
}
