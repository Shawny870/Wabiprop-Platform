    "WS_Bookings": [
      { "id": "recB1", "fields": { "Guest": ["recG1"], "Status": "Checked In", "Booking Type": "Overnight", "Booking Ref": "WS-TEST01", "Room": ["recR1"], "Check In": "2026-07-21T12:00:00.000Z", "Check Out": "2026-07-22T08:00:00.000Z" } }
