{
  "name": "details: 'today'/'tomorrow' parse into structured SAST datetimes instead of re-prompting (B7/F15, closes 12.1)",
  "comment": "Before B7 this exact message re-prompted forever: 'today' and 'tomorrow' were not in the date classifier, so 'today' was never recognised as a check-in and the guest could not book with relative dates (Master Transfer v4, 12.1). Only the time-of-day is pinned here (12:00Z = 14:00 SAST check-in, 08:00Z = 10:00 SAST check-out) because the calendar date depends on when the suite runs; test/dates.test.js pins the SAST date resolution exactly against a frozen clock, including the 00:00-01:59 SAST window where the UTC date disagrees.",
  "seed": {
    "WS_Properties": [
      { "id": "recP1", "fields": { "Property Name": "Test Lodge", "Phone Number ID": "111000111000", "City": "Testville", "Notify Phone": "27831112222" } }
    ],
    "WS_Rates": [
      { "id": "recRATE1", "fields": { "Rate Name": "Standard Overnight", "Rate Type": "Per Night", "Amount": 350, "Active": true, "Property": ["recP1"] } }
    ],
    "WS_Rooms": [
      { "id": "recR1", "fields": { "Room Name": "Room 1", "Status": "Available", "Property": ["recP1"] } }
    ],
    "WS_Guests": [
      { "id": "recG1", "fields": { "Guest Name": "Unknown", "Phone Number": "27821234567", "Session State": "AWAITING_DETAILS" } }
    ],
    "WS_Cleaners": [],
    "WS_Bookings": []
  },
  "message": { "from": "27821234567", "text": "John Smith\ntoday\ntomorrow" },
  "expect": {
    "status": 200,
    "writes": [
      { "op": "update", "table": "WS_Guests", "id": "recG1", "fields": { "Guest Name": "John Smith", "Session State": "AWAITING_OCCUPANCY" } },
      {
        "op": "create", "table": "WS_Bookings",
        "fields": {
          "Guest": ["recG1"],
          "Booking Type": "Overnight",
          "Status": "Enquiry",
          "Notes": "Check-in: today | Check-out: tomorrow",
          "Check In": "re:^\\d{4}-\\d{2}-\\d{2}T12:00:00\\.000Z$",
          "Check Out": "re:^\\d{4}-\\d{2}-\\d{2}T08:00:00\\.000Z$",
          "Room": ["recR1"],
          "Payment Status": "Unpaid"
        }
      },
      { "op": "update", "table": "WS_Bookings", "fields": { "Booking Ref": "re:^WS-[A-Z0-9]{6}$" } }
    ],
    "sends": [
      { "to": "27830000001", "includes": ["New booking enquiry from John Smith", "Check-in: today", "Check-out: tomorrow"] },
      { "to": "27821234567", "includes": ["Thanks John Smith", "How many of you are staying", "1 - Just me", "2 - Two of us"] }
    ]
  }
}
